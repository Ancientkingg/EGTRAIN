# EditorConfig: https://editorconfig.org
# Keeps the codebase's existing tab-indentation convention consistent
# across editors.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,h,hpp,cc,cxx}]
indent_style = tab
indent_size = 4

# Vendored third-party library — leave its existing style untouched.
[{pugixml.cpp,pugixml.hpp}]
indent_style = unset
indent_size = unset
trim_trailing_whitespace = false

[*.{ui,qrc,xml}]
indent_style = space
indent_size = 2

[CMakeLists.txt]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
